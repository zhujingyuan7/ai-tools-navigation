# ============================================
# Notion API 配置
# ============================================

# Notion Integration Token (Internal Integration Token)
# 获取方式：
# 1. 访问 https://www.notion.so/my-integrations
# 2. 创建新的 Integration
# 3. 复制 "Internal Integration Token"
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database ID
# 获取方式：
# 1. 在 Notion 中打开你的数据库页面
# 2. 从 URL 中复制数据库 ID
#    URL 格式: https://www.notion.so/your-workspace/[DATABASE_ID]?v=...
#    DATABASE_ID 是 32 位字符，不包含连字符
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# 配置说明
# ============================================
#
# 1. 创建 Notion Integration
#    - 访问 https://www.notion.so/my-integrations
#    - 点击 "+ New integration"
#    - 填写名称（如：AI Tools Navigation）
#    - 选择关联的 workspace
#    - 复制生成的 "Internal Integration Token"
#
# 2. 创建 Notion 数据库
#    - 在 Notion 中创建新的数据库
#    - 按照文档说明设置表结构
#    - 复制数据库 ID（从 URL 中提取）
#
# 3. 连接 Integration 到数据库
#    - 打开数据库页面
#    - 点击右上角 "..."
#    - 选择 "Add connections"
#    - 选择你创建的 Integration
#
# 4. 配置环境变量
#    - 复制 .env.example 到 .env.local
#    - 填写真实的 NOTION_API_KEY 和 NOTION_DATABASE_ID
#    - 重启开发服务器
#
# ============================================
# 数据库表结构
# ============================================
#
# 必需字段：
#
# 字段名          | 类型         | 说明
# ---------------|--------------|-------------------
# Name           | Title        | 工具名称（默认）
# description     | Text         | 工具描述
# description_en | Text         | 英文描述（可选）
# category        | Select       | 分类
# tags            | Multi-select | 标签
# website         | URL          | 官网链接
# featured        | Checkbox     | 是否精选
# rating          | Number       | 评分（0-5）
# priceType       | Select       | 价格类型
# status          | Select       | 状态
# views           | Number       | 访问量
# favorites       | Number       | 收藏数
# isNew           | Checkbox     | 是否新工具
# isHot           | Checkbox     | 是否热门
# addedAt         | Date         | 添加日期
#
# 可选字段：
#
# 字段名          | 类型         | 说明
# ---------------|--------------|-------------------
# price           | Text         | 价格详情
# screenshots     | Multi-select | 截图URL（数组）
# features        | Multi-select | 功能特点（数组）
# pros            | Multi-select | 优点（数组）
# cons            | Multi-select | 缺点（数组）
# seoTitle        | Text         | SEO 标题
# seoDescription  | Text         | SEO 描述
# seoKeywords     | Multi-select | SEO 关键词（数组）
#
# ============================================
# Select 选项建议
# ============================================
#
# category 选项：
# - chatbots
# - image-tools
# - coding-assistants
# - writing-tools
# - productivity
# - research
#
# priceType 选项：
# - free
# - freemium
# - paid
#
# status 选项：
# - draft
# - published
# - unpublished
#
# ============================================
# 图标设置
# ============================================
#
# 工具图标可以通过以下方式设置：
# 1. 在 Notion 页面中添加 emoji 图标（推荐）
# 2. 上传图标图片
# 3. 使用默认图标 🤖
#
# ============================================
# 封面图片
# ============================================
#
# 工具封面可以通过以下方式设置：
# 1. 上传封面图片到 Notion 页面
# 2. 不设置则使用默认纸张质感
#
# ============================================
# 注意事项
# ============================================
#
# 1. NOTION_API_KEY 必须以 "secret_" 开头
# 2. NOTION_DATABASE_ID 是 32 位字符
# 3. 确保 Integration 已连接到数据库
# 4. 工具状态必须为 "published" 才会显示
# 5. 建议在 .env.local 中配置，不要提交到 Git
#
# ============================================
